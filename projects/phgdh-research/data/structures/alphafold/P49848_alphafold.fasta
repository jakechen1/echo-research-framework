  <script>
    function applyInternalStyles() {
      const widget = document.querySelector('gen-search-widget');
      
      // Check if the widget and its shadowRoot are ready
      if (widget && widget.shadowRoot) {
        // Check if we already added the style to avoid duplicates
        if (widget.shadowRoot.querySelector('#custom-widget-styles')) return;
  
        const style = document.createElement('style');
        style.id = 'custom-widget-styles';
        style.textContent = `
          div[role="dialog"], 
          div[aria-label="Search widget"] {
            position: fixed !important;
            left: auto !important;
            right: 0 !important;
            top: 50% !important;   
            transform: translateY(-50%) !important; 
            width: 50% !important; 
            max-width: 50vw !important;
            border-radius: 8px 0 0 8px !important;
            overflow: hidden !important;
            z-index: 9999 !important;
          }

          .backdrop {
            background-color: rgba(0, 0, 0, 0.8) !important;
            backdrop-filter: blur(5px) !important;
          }

          .search-bar-container {
            margin-left: -103px !important; /* Note: Verify if this negative margin causes issues */
            background: #f0f0f0 !important;
          }

          /* Hiding the requested elements */
          .filters-container, 
          ucs-datasource-filters, 
          .search-toolbar,
          .dropdown {
            display: none !important;
            margin-left: -103px !important;
          }
        `;
        widget.shadowRoot.appendChild(style);
      }
    }
  
    // This observes the page and runs the code when the widget appears
    const observer = new MutationObserver((mutations) => {
      const widget = document.querySelector('gen-search-widget');
      if (widget && widget.shadowRoot) {
        applyInternalStyles();
      }
    });
  
    observer.observe(document.body, { childList: true, subtree: true });
  </script>
