{
  "filename_glob": "aim2_top20_inhibitors.csv",
  "format": "csv",
  "header": true,
  "columns": [
    {"index": 1, "name": "rank",            "type": "int"},
    {"index": 2, "name": "pchembl",         "type": "float"},
    {"index": 3, "name": "smiles",          "type": "smiles"},
    {"index": 4, "name": "chembl_id",       "type": "string", "pattern": "^CHEMBL\\d+$"},
    {"index": 5, "name": "assay_type",      "type": "string"},
    {"index": 6, "name": "standard_type",   "type": "string"},
    {"index": 7, "name": "standard_value",  "type": "float"},
    {"index": 8, "name": "standard_units",  "type": "string"}
  ],
  "delimiter": ","
}
